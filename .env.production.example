# TwisterLab Production Environment Variables
# Copy this file to .env and customize values

# ==============================================
# Database Configuration
# ==============================================
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=twisterlab
POSTGRES_USER=twisterlab

# ==============================================
# Redis Configuration
# ==============================================
REDIS_PASSWORD=your_secure_redis_password_here

# ==============================================
# Application Configuration
# ==============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Agent Mode
AGENT_MODE=REAL
# Options: REAL, HYBRID, MOCK

# ==============================================
# Ollama LLM (Optional)
# ==============================================
# If running Ollama locally on host machine:
OLLAMA_HOST=http://host.docker.internal:11434
# If running Ollama in Docker:
# OLLAMA_HOST=http://ollama:11434

# ==============================================
# MCP Configuration
# ==============================================
MCP_LOG_LEVEL=INFO

# ==============================================
# Monitoring Configuration
# ==============================================
GRAFANA_PASSWORD=admin
# Change this in production!

# ==============================================
# PgAdmin (Optional - only with --profile tools)
# ==============================================
PGADMIN_EMAIL=admin@twisterlab.local
PGADMIN_PASSWORD=admin
# Change this in production!

# ==============================================
# Security (Production)
# ==============================================
# Uncomment and set these for production:
# JWT_SECRET_KEY=your_jwt_secret_key_here
# API_KEY=your_api_key_here
# ALLOWED_HOSTS=edgeserver.twisterlab.local,localhost

# ==============================================
# Backup Configuration (Optional)
# ==============================================
# BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
# BACKUP_RETENTION_DAYS=30
# S3_BUCKET=twisterlab-backups
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
