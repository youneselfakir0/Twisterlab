{
  "_comment": "Claude Desktop Configuration for TwisterLab MCP Server",
  "_instructions": "Copy this file to: Windows: %APPDATA%\\Claude\\claude_desktop_config.json, Mac: ~/Library/Application Support/Claude/claude_desktop_config.json",
  "_updated": "2026-05-21",
  "_server": "http://192.168.0.30:30080",
  "_version": "3.5.0",
  "_transport": "HTTP/REST (FastAPI native via mcp-remote)",
  
  "mcpServers": {
    "twisterlab": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://192.168.0.30:30080/api/v1/mcp/tools",
        "--allow-http"
      ],
      "env": {
        "MCP_LOG_LEVEL": "INFO",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    }
  },
  "_tools_available": {
    "agent_discovery": [
      "list_autonomous_agents - Discover all 20+ agents and their capabilities",
      "call_agent_tool - Execute any agent capability with parameters"
    ],
    
    "ticket_management": [
      "real-classifier_classify_ticket - Classify tickets (category, priority)",
      "real-resolver_resolve_ticket - Mark tickets as resolved with notes"
    ],
    
    "analysis": [
      "sentiment-analyzer_analyze_sentiment - Analyze text sentiment and tone",
      "code-review_analyze_code - Static code quality analysis",
      "code-review_security_scan - Security vulnerability detection"
    ],
    
    "monitoring": [
      "monitoring_collect_metrics - CPU, memory, disk, network metrics",
      "monitoring_system_health - Full system health with details"
    ],
    
    "operations": [
      "real-desktop-commander_execute_command - Execute safe system commands",
      "real-backup_create_backup - Create service/data backups",
      "browser_browse - Web browsing and content extraction"
    ],
    
    "orchestration": [
      "maestro_orchestrate - Multi-agent workflow coordination",
      "maestro_analyze_task - Analyze and route tasks intelligently"
    ]
  },
  "_tools_count": 20,
  "_network": {
    "edgeserver": "192.168.0.30 (K3s cluster)",
    "cortex": "192.168.0.20 (Ollama LLM server)",
    "mcp_port": 30080,
    "api_port": 30001,
    "grafana_port": 30300,
    "prometheus_port": 30090
  },
  "_usage_examples": {
    "classify_ticket": {
      "tool": "real-classifier_classify_ticket",
      "arguments": {
        "ticket_text": "The production server is down!"
      }
    },
    "analyze_sentiment": {
      "tool": "sentiment-analyzer_analyze_sentiment",
      "arguments": {
        "text": "I am very happy with the service!",
        "detailed": true
      }
    },
    "orchestrate_task": {
      "tool": "maestro_orchestrate",
      "arguments": {
        "task": "Resolve the database performance incident",
        "dry_run": false
      }
    },
    "create_backup": {
      "tool": "real-backup_create_backup",
      "arguments": {
        "service_name": "production-database"
      }
    },
    "execute_command": {
      "tool": "real-desktop-commander_execute_command",
      "arguments": {
        "command": "df -h",
        "timeout": 30
      }
    },
    "database_health": {
      "tool": "database_db_health",
      "arguments": {}
    },
    "cache_stats": {
      "tool": "cache_cache_stats",
      "arguments": {}
    },
    "security_scan": {
      "tool": "code-review_security_scan",
      "arguments": {
        "code": "password = 'secret123'"
      }
    }
  }
}