              {
                "name": "PYTHONPATH",
                "value": "/app/src"
              },
              {
                "name": "NOTION_TOKEN",
                "value": "ntn_p83568381507m9WWa5MaAxUsiEmDdzDvVb7daxAWxPy47l"
              },
              {
                "name": "NOTION_DEFAULT_DATABASE_ID",
                "value": "3431f21b3b068087845cd838474d5464"
              }
